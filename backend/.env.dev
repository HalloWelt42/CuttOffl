CUTTOFFL_HOST=127.0.0.1
CUTTOFFL_PORT=10036
CUTTOFFL_DATA_DIR=../data
CUTTOFFL_LOG_LEVEL=INFO

# CORS: komma-separierte Liste der erlaubten Origins. Leer lassen, um den
# Default zu nutzen (localhost:10036/10037). "*" ist erlaubt, schaltet
# dann aber allow_credentials auf False (Browser-Verhalten).
# CUTTOFFL_CORS_ORIGINS=http://127.0.0.1:10037,http://localhost:10037
